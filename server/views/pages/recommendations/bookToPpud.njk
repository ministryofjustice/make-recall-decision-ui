{% extends "../../partials/layout.njk" %}

{% set pageTitle = makePageTitle({ pageHeading: pageTitles[page.id], hasErrors: errors }) %}

{% block beforeContent %}
    {% if not recommendation.bookingMemento.failed %}
        {{ backLink() }}
    {% endif %}
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">

            {% if recommendation.bookingMemento.failed %}
                <div class="govuk-error-summary" aria-labelledby="error-summary-title" role="alert" data-module="govuk-error-summary" data-qa="error-list">
                    <h2 class="govuk-error-summary__title" id="error-summary-title">
                        There is a problem
                    </h2>
                    <div class="govuk-error-summary__body">
                        <p class='govuk-body'>
                            Something went wrong sending the booking to PPUD. Check PPUD to see what's there. You may have to add some details manually.
                        </p>
                        <a class='govuk-link' href='booking-summary'>View the information you tried to send to PPUD.</a>
                    </div>
                </div>
            {% else %}
                <div class="govuk-panel govuk-panel--confirmation">
                    <h1 class="govuk-panel__title">
                        {% if isInDeterminateSentences -%}
                            Booked on in PPUD
                        {%- elseif recommendation.ppudOffender -%}
                            Booked on to PPUD
                        {%- else -%}
                            Record created and booked on to PPUD
                        {%- endif %}
                    </h1>  

                    <div class="govuk-panel__body">
                        {{ recommendation.bookRecallToPpud.firstNames }} {{ recommendation.bookRecallToPpud.lastName }}
                    </div>
                    <div class="govuk-panel__body">
                        NOMIS number: <strong>{{ recommendation.personOnProbation.nomsNumber }}</strong>
                    </div>
                </div>
                <h2 class="govuk-heading-m">What happens next</h2>
                {% if isInDeterminateSentences %}
                    <p class='govuk-body'>
                     You’ve added this recall to PPUD and can issue the revocation order. A parole eligible casework (PEC) manager will be assigned to the case.
                    </p> 
                {% else %}
                    <p class='govuk-body'>
                    You’ve added this recall to PPUD. A band 4 case manager will review and decide what recall type to use.
                    </p> 
                {% endif %}
            
            {% endif %}
            <form novalidate method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                <div class='govuk-!-margin-top-6'>

                    {% if recommendation.bookingMemento.failed %}
                        <button class="govuk-button govuk-button--secondary">
                            Try again
                        </button>
                    {% else %}
                        <button class="govuk-button">
                            Continue
                        </button>
                    {% endif %}

                </div>
            </form>
        </div>
    </div>
{% endblock %}

{% block bodyEnd %}
    {{ super() }}
    <script src="{{ '/assets/js/disableSubmitButtonOnClick.js' | assetMap }}" defer></script>
{% endblock %}
