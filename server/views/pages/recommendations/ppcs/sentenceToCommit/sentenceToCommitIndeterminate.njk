{% extends "../../../../partials/layout.njk" %}

{% set pageTitle = makePageTitle({ pageHeading: pageTitles[page.id], hasErrors: errors }) %}
{% set editText = 'Edit' %}
{% set editIdPrefix = 'edit-' %}

{% block beforeContent %}
    {{ backLink() }}
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">
            {{ heading(pageHeadings[page.id]) }}
            <p class="govuk-body">
                This is the sentence you've selected from PPUD. You can edit anything that's wrong. This will update what's in PPUD.
            </p>

                {{ heading("Your recall booking", 2, "m") }}

                {% set indeterminateTermRows = [] %}
                {% for term in offence.terms %}
                    {% if term.code == "FP" %}
                        {% set _ = indeterminateTermRows.push({ key: "Full punishment", value: hyphenForBlank(formatTerm(term)), actions: [{ id: editIdPrefix+'fullpunishment', text: editText, href: '#', visuallyHidden: 'full punishment' }] }) %}
                    {% endif %}
                {% endfor %}


                {{ summaryList({
                    id: " indeterminate-sentence-to-commit",
                    rows: [
                        { key: "Custody type", value: hyphenForBlank(sentenceSummary.custodyType) },
                        { key: "Offence",  value: hyphenForBlank(sentenceSummary.offence), actions: [{ id: editIdPrefix+'offence', text: editText, href: '#', visuallyHidden: 'offence' }] },
                        { key: "Release date", value: hyphenForBlank(formatDateTimeFromIsoString({ isoDate: sentenceSummary.releaseDate })), actions: [{ id: editIdPrefix+'releasedate', text: editText, href: '#', visuallyHidden: 'release date' }] },
                        { key: "Sentencing Court", value: hyphenForBlank(sentenceSummary.sentencingCourt), actions: [{ id: editIdPrefix+'sentencingcourt', text: editText, href: '#', visuallyHidden: 'sentencing court' }] },
                        { key: "Date of sentence", value: hyphenForBlank(formatDateTimeFromIsoString({ isoDate: sentenceSummary.dateOfSentence })), actions: [{ id: editIdPrefix+'dateofentence', text: editText, href: '#', visuallyHidden: 'date of sentence' }] },
                        { key: "Tarrif expiry date", value: hyphenForBlank(formatDateTimeFromIsoString({ isoDate: sentenceSummary.tarrifExpiryDate })), actions: [{ id: editIdPrefix+'tarrifexpirydate', text: editText, href: '#', visuallyHidden: 'tarrif expiry date' }] }
                    ].concat(indeterminateTermRows)
                }) }}

            <form novalidate method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                {{ formSubmitButton() }}
            </form>
        </div>
    </div>
{% endblock %}