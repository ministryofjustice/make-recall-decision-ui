{% extends "../../partials/layout.njk" %}

{% set pageTitle = makePageTitle({ pageHeading: pageTitles[page.id], hasErrors: errors }) %}

{% block beforeContent %}
    {{ backLink() }}
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">
            {% include '../../partials/error-summary.njk' %}

            <h1 class="govuk-heading-l">{{ pageHeadings[page.id] }}</h1>

            <p class="govuk-body">
                Check the previous convictions (MG16) document or NOMIS to find the CRO.
            </p>

            {% if recommendation.prisonOffender.cro %}
                <h2 class='govuk-heading-m govuk-!-margin-bottom-0'>From Part A</h2>
                <dl class="car-text-list">
                    <div class="car-text-list__row">
                        <dt class="car-text-list__key">CRO</dt>
                        <dd class="car-text-list__value" data-qa="nomisCro">{{ recommendation.prisonOffender.cro }}</dd>
                    </div>
                </dl>
            {% endif %}

            {% if recommendation.ppudOffender %}
                <h2 class='govuk-heading-m govuk-!-margin-bottom-0'>From PPUD</h2>
                {% if recommendation.ppudOffender.croOtherNumber %}
                    <dl class="car-text-list">
                        <div class="car-text-list__row">
                            <dt class="car-text-list__key">CRO</dt>
                            <dd class="car-text-list__value" data-qa="ppudCro">{{ recommendation.ppudOffender.croOtherNumber }}</dd>
                        </div>
                    </dl>
                {% else %}
                    <p class="govuk-body" data-qa="ppudCro">There is a PPUD record but this field is blank.</p>
                {% endif %}
            {% endif %}

            <form novalidate method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                {{ govukInput({
                    label: {
                        text: "CRO",
                        classes: "govuk-label--m"
                    },
                    hint: {
                        text: 'For example, 123456/05X'
                    },
                    id: "cro",
                    name: "cro",
                    type: 'text',
                    classes: "govuk-input--width-20",
                    value: values.cro,
                    errorMessage: errorMessage(errors.cro)
                }) }}

                {{ formSubmitButton() }}
            </form>
        </div>
    </div>
{% endblock %}
