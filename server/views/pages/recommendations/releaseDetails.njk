{% extends "../../partials/layout.njk" %}

{% block beforeContent %}
  {{ backLink() }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <form novalidate method="post">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
        {% if recommendation.previousReleases.previousReleaseDates.length %}
          <input type="hidden" name="previousReleaseDates"
                  value="{% for date in recommendation.previousReleases.previousReleaseDates %}{{ date }}|{% endfor %}" />
        {% endif %}
        <input type="hidden" name="dateOfRelease" value="{{recommendation.previousReleases.lastReleaseDate}}" />

        {{ heading(pageHeadings[page.id]) }}
        {{ deliusDetailsMessage() }}

        {{
          summaryList({
              rows: [
                { key: 'Releasing prison or custodial establishment', value: recommendation.previousReleases.lastReleasingPrisonOrCustodialEstablishment | defaultValue | safe },
                { key: 'Date of current release', value: formatDateTimeFromIsoString({isoDate: recommendation.previousReleases.lastReleaseDate, dateOnly: true}) | defaultValue | safe }
              ]
            })
        }}

        <button
          name='continueButton'
          value='{{ '1' if recommendation.previousReleases.previousReleaseDates.length else '0' }}'
          class="govuk-button govuk-!-margin-top-7">Continue</button>
      </form>
    </div>
  </div>
{% endblock %}
