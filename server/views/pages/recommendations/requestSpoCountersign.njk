{% extends "../../partials/layout.njk" %}

{% set pageTitle = makePageTitle({ pageHeading: pageTitles[page.id], hasErrors: errors }) %}

{% block beforeContent %}
    {{ backLink() }}
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">

            <h1 class="govuk-heading-l">{{ pageHeadings[page.id] }}</h1>

            <p class='govuk-body'>To request your line manager's countersignature:</p>

            <ol class='govuk-list govuk-list--number'>
                <li>
                    Copy this link:
                    <div class='govuk-share-widget'>
                        <div class='mid-grey-panel'>
                            <pre class='govuk-body govuk-!-margin-0 govuk-!-padding-1' data-js='copy-to-clipboard-text' data-qa='case-link'>{{ link }}</pre>
                        </div>
                        <button class='govuk-button govuk-button--secondary govuk-!-margin-top-2' data-js='copy-to-clipboard-btn'>Copy</button>
                    </div>
                </li>
                <li>Paste it into an email or Teams message.</li>
                <li>Send it to your manager.</li>
            </ol>
             <div>
                <a href='{{urlInfo.pageBase}}task-list#countersign' class='govuk-button govuk-button--primary'>Continue</a>
            </div>
        </div>
    </div>

  <script id="ss-popup-3742462" nonce="{{ cspNonce }}">
    var _ssq = { 'cid': 3742462 , 'custom_variable1' : '{{ recommendation.id }}' }
    window.onload = function() {
      var ss = document.createElement('script')
      ss.type = 'text/javascript'
      ss.async = true
      ss.src = ('https:' == document.location.protocol ? 'https://' : 'http://') + 'www.smartsurvey.co.uk/s/popup/' + _ssq.cid + '/js/'
      var s = document.getElementsByTagName('script')[0]
      s.parentNode.insertBefore(ss, s)
    }
  </script>
{% endblock %}

{% block bodyEnd %}
    {{ super() }}
    <script src="{{ '/assets/js/copyToClipboard.js' | assetMap }}" defer></script>
{% endblock %}
