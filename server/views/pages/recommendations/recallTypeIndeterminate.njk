{%- from "moj/components/ticket-panel/macro.njk" import mojTicketPanel -%}
{%- from "components/heading/macro.njk" import heading %}

{% extends "../../partials/layout.njk" %}

{% set pageTitle = makePageTitle({pageHeading: pageTitles.recallType, hasErrors: errors}) %}

{% set ticketPanelHtml %}
    {{ heading(recommendation.personOnProbation.name + ' must be given an emergency standard recall, if recalled', 2, 'm')}}
    <p class="govuk-body">
        This is based on their sentence information. If this does not look right, you can go back to amend your answers.
    </p>
{% endset %}

{% block beforeContent %}
    {{ backLink() }}
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">
            {% include '../../partials/error-summary.njk' %}
            <form novalidate method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                <input type="hidden" name="crn" value="{{ recommendation.crn }}"/>

                {{ heading(pageHeadings.recallType) }}

                    {{
                        mojTicketPanel({
                            items: [{
                                html: ticketPanelHtml,
                                classes: "moj-ticket-panel__content--blue"
                            }]
                        })
                    }}
                    {{ 
                        govukRadios({
                            idPrefix: "recallType",
                            name: "recallType",
                            fieldset: {
                                legend: {
                                    text: "Select your recommendation",
                                    classes: "govuk-!-font-weight-bold"
                                }
                            },
                            items: radioCheckboxItems({
                                items: formOptions.recallTypeIndeterminate,
                                currentValues: inputDisplayValues.value
                            }),
                            errorMessage: errorMessage(errors.recallType)
                        })
                    }}
               
                {{ formSubmitButton() }}
            </form>
        </div>
    </div>
{% endblock %}
