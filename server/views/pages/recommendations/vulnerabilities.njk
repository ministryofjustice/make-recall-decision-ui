{% extends "../../partials/layout.njk" %}

{% set pageTitle = makePageTitle({ pageHeading: pageTitles[page.id], hasErrors: errors }) %}

{% block beforeContent %}
    {{ backLink() }}
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">
            {% include '../../partials/error-summary.njk' %}
            <form novalidate method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                <div class="govuk-form-group{% if errors.vulnerabilities %} govuk-form-group--error{% endif %}">
                  <fieldset class="govuk-fieldset" aria-describedby="vulnerabilities-body-text{% if errors.vulnerabilities %} vulnerabilities-error{% endif %}">
                    <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
                        <h1 class="govuk-fieldset__heading">
                            {{ pageHeadings[page.id] }}
                        </h1>
                    </legend>
                      <p id="vulnerabilities-body-text" class="govuk-body">
                         Think about if the recall, or the circumstances that led to it, could affect vulnerabilities or needs. Select all that apply.
                      </p>
                      <p id="vulnerabilities-error" class="govuk-error-message">
                          <span class="govuk-visually-hidden">Error:</span> {{ errors.vulnerabilities.text }}
                      </p>
                      <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                        {# Normal vulnerabilities first #}
                        {% set lastCategory = '' %}
                        {% for item in nonExclusive %}
                            {% if item.category != lastCategory %}
                                {% set lastCategory = item.category %}
                                <h2 class="govuk-heading-s govuk-!-margin-top-7">{{ item.category }}</h2>
                                    {% if item.categoryHint %}
                                        <p id="vulnerabilities-{{item.value}}-hint" class="govuk-hint">
                                            {{ renderString(item.categoryHint, { fullName: fullName }) }}
                                        </p>
                                    {% endif %}
                            {% endif %}

                            {% set selected = findListItemByValue({ items: inputDisplayValues, value: item.value }) %}

                          <div class="govuk-checkboxes__item">
                                <input class="govuk-checkboxes__input"
                                       id="{{ item.value }}"
                                       name="vulnerabilities"
                                       type="checkbox"
                                       value="{{ item.value }}"
                                       {% if selected %}checked{% endif %}>
                                <label class="govuk-label govuk-checkboxes__label" for="{{ item.value }}">
                                    {{ item.text }}
                                </label>
                              <p id="{{ item.value }}-error" class="govuk-error-message">
                                  <span class="govuk-visually-hidden">Error:</span> {{ errors[item.value].text }}
                              </p>
                            </div>
                        {% endfor %}

                        {# Exclusive last #}
                        {% if exclusive %}
                            <h2 class="govuk-heading-s govuk-!-margin-top-7">{{ exclusive.category }}</h2>
                            {% if exclusive.categoryHint %}
                                <p id="vulnerabilities-{{exclusive.value}}-hint" class="govuk-hint">
                                    {{ exclusive.categoryHint }}
                                </p>
                            {% endif %}

                            {# Main exclusive checkbox #}
                            <div class="govuk-checkboxes__item">
                                <input class="govuk-checkboxes__input"
                                       id="{{ exclusive.value }}"
                                       name="vulnerabilities"
                                       type="checkbox"
                                       value="{{ exclusive.value }}"
                                       data-aria-controls="conditional-{{ exclusive.value }}"
                                       {% if exclusiveSelected %}checked{% endif %}
                                       aria-describedby = "{{ exclusive.value }}-hint">
                                <label class="govuk-label govuk-checkboxes__label" for="{{ exclusive.value }}">
                                    {{ exclusive.text }}
                                </label>
                                <div id="{{ exclusive.value }}-hint" class="govuk-hint govuk-checkboxes__hint">
                                    Select this only if you have not selected any vulnerabilities or needs.
                                </div>
                                <p id="{{ exclusive.value }}-error" class="govuk-error-message">
                                    <span class="govuk-visually-hidden">Error:</span>  {{ errors[exclusive.value].text }}
                                </p>
                            </div>

                            {# Conditional radios under the main checkbox #}
                            <div class="govuk-checkboxes__conditional{% if not exclusiveSelected %} govuk-checkboxes__conditional--hidden{% endif %}"
                                 id="conditional-{{ exclusive.value }}">
                                <div class="govuk-radios govuk-radios--small">
                                    {% for subitem in exclusive.items %}
                                        {% set selected = findListItemByValue({ items: inputDisplayValues, value: subitem.value }) %}
                                        <div class="govuk-radios__item">
                                            <input class="govuk-radios__input"
                                                   id="{{ subitem.value }}"
                                                   name="vulnerabilities"
                                                   type="radio"
                                                   value="{{ subitem.value }}"
                                                   data-behaviour="exclusive"
                                                   {% if selected %}checked{% endif %}>
                                            <label class="govuk-label govuk-radios__label" for="{{ subitem.value }}">
                                                {{ subitem.text }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </fieldset>
                </div>
                {{ formSubmitButton({ label: "Continue to the next step" }) }}
            </form>
        </div>
    </div>
{% endblock %}
