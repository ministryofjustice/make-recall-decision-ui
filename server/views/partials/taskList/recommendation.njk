{% set suitabilityForFixedTermRecall = true %}

{% if ftr56Enabled %}

  {% if recommendation.sentenceGroup == 'ADULT_SDS' %}
    {% set suitabilityForFixedTermRecall =
      hasData(recommendation.isChargedWithOffence) and
      hasData(recommendation.isServingTerroristOrNationalSecurityOffence) and
      hasData(recommendation.isAtRiskOfInvolvedInForeignPowerThreat) and
      hasData(recommendation.wasReferredToParoleBoard244ZB) and
      hasData(recommendation.wasRepatriatedForMurder) and
      hasData(recommendation.isServingSOPCSentence) and
      hasData(recommendation.isServingDCRSentence)
    %}

  {% elif recommendation.sentenceGroup == 'YOUTH_SDS' %}
    {% set suitabilityForFixedTermRecall =
      hasData(recommendation.isYouthSentenceOver12Months) and
      hasData(recommendation.isYouthChargedWithSeriousOffence)
    %}

  {% else %}
    {% set suitabilityForFixedTermRecall = true %}
  {% endif %}

{% else %}

  {# 🔒 existing logic preserved (no regression) #}
  {% set suitabilityForFixedTermRecall =
    hasData(recommendation.isUnder18) or
    hasData(recommendation.licenceConditionsBreached.isMappaLevelAbove1) or
    hasData(recommendation.cvlLicenceConditionsBreached.isSentence12MonthsOrOver) or
    hasData(recommendation.cvlLicenceConditionsBreached.hasBeenConvictedOfSeriousOffence)
  %}

{% endif %}

<li>
    <h2 class="moj-task-list__section" id='heading-recommendation'>
        Make your recommendation
    </h2>
    <ul class="moj-task-list__items">
        {% if ftr56Enabled %}
            {% if recommendation.sentenceGroup == 'ADULT_SDS' %}
                <li class="moj-task-list__item">
                    <span class="moj-task-list__task-name">
                        <a aria-describedby='task-list-status-mappa' href="{{ changeLinkUrl({ pageUrlSlug: 'check-mappa-information', urlInfo: urlInfo, fromAnchor: 'heading-recommendation' }) }}">MAPPA information to assess recall type</a>
                    </span>
                    <span id='task-list-status-mappa'>{{ taskStatus({ hasData: hasData(recommendation.personOnProbation.ftr56MappaReviewed) }) }}</span>
                </li>
            {% endif %}
            {% if recommendation.sentenceGroup == 'ADULT_SDS' or recommendation.sentenceGroup == 'YOUTH_SDS' %}
                <li class="moj-task-list__item">
                    <span class="moj-task-list__task-name">
                        <a aria-describedby='task-list-status-suitabilityForFixedTermRecall' href="{{ changeLinkUrl({ pageUrlSlug: 'suitability-for-fixed-term-recall', urlInfo: urlInfo, fromAnchor: 'heading-recommendation' }) }}">Suitability for standard or fixed term recall</a>
                    </span>
                    <span id='task-list-status-suitabilityForFixedTermRecall'>{{ taskStatus({ hasData: suitabilityForFixedTermRecall }) }}</span>
                </li>
            {% endif %}
        {% else %}
           {% if recommendation.isIndeterminateSentence == false and recommendation.isExtendedSentence == false %}
                 <li class="moj-task-list__item">
                     <span class="moj-task-list__task-name">
                         <a aria-describedby='task-list-status-suitabilityForFixedTermRecall' href="{{ changeLinkUrl({ pageUrlSlug: 'suitability-for-fixed-term-recall', urlInfo: urlInfo, fromAnchor: 'heading-recommendation' }) }}">Suitability for standard or fixed term recall</a>
                     </span>
                     <span id='task-list-status-suitabilityForFixedTermRecall'>{{ taskStatus({ hasData: suitabilityForFixedTermRecall }) }}</span>
                 </li>
           {% endif %}
        {% endif %}
        <li class="moj-task-list__item">
            <span class="moj-task-list__task-name">
                <a aria-describedby='task-list-status-recallType' href="{{ changeLinkUrl({ pageUrlSlug: whatDoYouRecommendPageUrlSlug, urlInfo: urlInfo, fromAnchor: 'heading-recommendation' }) }}">What you recommend</a>
            </span>
            <span id='task-list-status-recallType'>{{ taskStatus({ hasData: hasData(recommendation.recallType.selected) }) }}</span>
        </li>
        <li class="moj-task-list__item">
            <span class="moj-task-list__task-name">
                <a aria-describedby='task-list-status-decisionDateTime' href="{{ changeLinkUrl({ pageUrlSlug: 'spo-agree-to-recall', urlInfo: urlInfo, fromAnchor: 'heading-recommendation' }) }}">When did the SPO agree this recall?</a>
            </span>
            <span id='task-list-status-decisionDateTime'>{{ taskStatus({ hasData: hasData(recommendation.decisionDateTime) }) }}</span>
        </li>
    </ul>
</li>
